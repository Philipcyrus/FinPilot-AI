# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep secrets out; the template is committed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# FinPilot local DB
prisma/*.db
prisma/*.db-journal
*.db

# AI assistant files & local context (not for the public repo)
CLAUDE.md
AGENTS.md
.claude/
.cursor/
.aider*
.continue/
.mcp.json
**/*.local.*

# scratch / local dev utilities
/scripts/check-engines.ts

# personal / sensitive data exports
*.csv
!docs/**/*.csv
secrets.*
*.key

# product brief / prompt spec (local-only)
docs/Code_prompt.md
docs/*prompt*
