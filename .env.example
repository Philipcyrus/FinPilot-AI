# FinPilot AI — environment configuration
# Everything works with NO keys (deterministic engine + free no-key data sources).
# Add ANY ONE free LLM key below to unlock the conversational multi-agent AI.

# --- Free LLM providers (pick one; auto-detected in this priority order) ---
# OpenRouter — free models, get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini — generous free tier, https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Groq — fast free inference, https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — fully local & offline (run `ollama serve` first)
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Force a specific provider (optional): openrouter | gemini | groq | ollama | none
# AI_PROVIDER=
